---
import Layout from "../layouts/Layout.astro";
import ScreeningRow from "../components/ScreeningRow.astro";
import { data, screeningsByDay } from "../data.ts";

const days = [...screeningsByDay().entries()].sort();
const HE_DAY_NAMES = ["יום ראשון", "יום שני", "יום שלישי", "יום רביעי", "יום חמישי", "יום שישי", "שבת"];
const EN_DAY_NAMES = ["Sunday", "Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday"];
function dayLabel(iso: string, names: string[]) {
  const d = new Date(iso + "T00:00:00");
  return `${names[d.getDay()]} · ${d.getDate()}/${d.getMonth() + 1}`;
}
const dayLabelHe = (iso: string) => dayLabel(iso, HE_DAY_NAMES);
const dayLabelEn = (iso: string) => dayLabel(iso, EN_DAY_NAMES);
---
<Layout title="לוח זמנים">
  <div class="section-heading">
    <h1 data-he="לוח זמנים" data-en="Schedule">לוח זמנים</h1>
    <span class="section-heading__count">{data.screenings.length} <span data-he="הקרנות" data-en="screenings">הקרנות</span></span>
  </div>

  <p style="color:var(--fg-dim);margin-bottom:2rem" data-he="כל ההקרנות מסודרות לפי יום ושעה. לחיצה על שם הסרט פותחת את עמוד הסרט עם פרטים מלאים וכפתור לכרטיסים." data-en="All screenings, grouped by day and time. Click a film name for full details and ticket links.">
    כל ההקרנות מסודרות לפי יום ושעה. לחיצה על שם הסרט פותחת את עמוד הסרט עם פרטים מלאים וכפתור לכרטיסים.
  </p>

  <nav style="display:flex;gap:0.5rem;flex-wrap:wrap;margin-bottom:2rem">
    {days.map(([k]) => <a href={`#day-${k}`} class="pill pill--ghost" data-he={dayLabelHe(k)} data-en={dayLabelEn(k)}>{dayLabelHe(k)}</a>)}
  </nav>

  <div class="schedule">
    {days.map(([day, screenings]) => (
      <section id={`day-${day}`} class="schedule__day">
        <h2><span data-he={dayLabelHe(day)} data-en={dayLabelEn(day)}>{dayLabelHe(day)}</span> <span style="color:var(--fg-faint);font-size:0.7em">{screenings.length}</span></h2>
        <div class="screening-list">
          {screenings.map((s) => <ScreeningRow screening={s} showDate={false} />)}
        </div>
      </section>
    ))}
  </div>
</Layout>
