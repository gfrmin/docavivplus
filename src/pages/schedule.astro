---
import Layout from "../layouts/Layout.astro";
import { data, filmBySlug, venueById, screeningsByDay, formatTime } from "../data.ts";

const days = [...screeningsByDay().entries()].sort();
const HE_DAY_NAMES = ["יום ראשון", "יום שני", "יום שלישי", "יום רביעי", "יום חמישי", "יום שישי", "שבת"];
function dayLabel(iso: string) {
  const d = new Date(iso + "T00:00:00");
  return `${HE_DAY_NAMES[d.getDay()]} · ${d.getDate()}/${d.getMonth() + 1}`;
}
---
<Layout title="לוח זמנים">
  <div class="section-heading">
    <h2 data-he="לוח זמנים" data-en="Schedule">לוח זמנים</h2>
    <span class="section-heading__count">{data.screenings.length} <span data-he="הקרנות" data-en="screenings">הקרנות</span></span>
  </div>

  <p style="color:var(--fg-dim);margin-bottom:2rem" data-he="כל ההקרנות מסודרות לפי יום ושעה. לחיצה על שם הסרט פותחת את עמוד הסרט עם פרטים מלאים וכפתור לכרטיסים." data-en="All screenings, grouped by day and time. Click a film name for full details and ticket links.">
    כל ההקרנות מסודרות לפי יום ושעה. לחיצה על שם הסרט פותחת את עמוד הסרט עם פרטים מלאים וכפתור לכרטיסים.
  </p>

  <nav style="display:flex;gap:0.5rem;flex-wrap:wrap;margin-bottom:2rem">
    {days.map(([k]) => <a href={`#day-${k}`} class="pill pill--ghost">{dayLabel(k)}</a>)}
  </nav>

  <div class="schedule">
    {days.map(([day, screenings]) => (
      <section id={`day-${day}`} class="schedule__day">
        <h2>{dayLabel(day)} <span style="color:var(--fg-faint);font-size:0.7em">{screenings.length}</span></h2>
        <div class="screening-list">
          {screenings.map((s) => {
            const film = s.filmSlug ? filmBySlug.get(s.filmSlug) : undefined;
            const venue = s.venueId ? venueById.get(s.venueId) : undefined;
            return (
              <div class="screening-row">
                <span class="screening-row__time">{formatTime(s.start)}</span>
                <span class="screening-row__venue" style="min-width:11rem">{venue?.nameHe ?? "—"}</span>
                {film
                  ? <a href={`/films/${film.slug}/`} style="flex:2;color:var(--fg)" data-he={film.titleHe} data-en={film.titleEn || film.titleHe}>{film.titleHe}{film.titleEn && <span style="color:var(--fg-faint)"> · {film.titleEn}</span>}</a>
                  : <span style="flex:2;color:var(--fg-dim)">{s.infoText}</span>}
                {s.isPremiere && <span class="screening-row__premiere" data-he="בנוכחות היוצרים" data-en="Q&A">בנוכחות היוצרים</span>}
                {s.ticketUrl && <a class="screening-row__btn" href={s.ticketUrl} target="_blank" rel="noopener" data-he="לכרטיסים" data-en="Tickets">לכרטיסים</a>}
              </div>
            );
          })}
        </div>
      </section>
    ))}
  </div>
</Layout>
