---
import type { Film } from "../data.ts";
import { countryHe, countryEn, hasRealPoster, sectionHue, nextScreeningForFilm, formatHebrewDate, formatEnDate, formatTime } from "../data.ts";

export interface Props { film: Film; }
const { film } = Astro.props;
const cHe = countryHe(film.countryHe);
const cEn = countryEn(film.countryHe);
const realPoster = hasRealPoster(film);
const hue = sectionHue(film.section || film.titleHe || "");
const next = nextScreeningForFilm(film);
const nextHe = next ? `${formatHebrewDate(next.start)} · ${formatTime(next.start)}` : "";
const nextEn = next ? `${formatEnDate(next.start)} · ${formatTime(next.start)}` : "";
---
<a class="film-card" href={`/films/${film.slug}/`}>
  {realPoster ? (
    <img class="film-card__poster" src={film.posterUrl} alt="" loading="lazy" decoding="async" />
  ) : (
    <div class="film-card__poster film-card__poster--placeholder" style={`--hue:${hue}`}>
      <span class="film-card__poster-title" data-he={film.titleHe} data-en={film.titleEn || film.titleHe}>{film.titleHe}</span>
    </div>
  )}
  <div class="film-card__body">
    {film.section && <div class="film-card__section">{film.section}</div>}
    <div class="film-card__title" data-he={film.titleHe} data-en={film.titleEn || film.titleHe}>{film.titleHe}</div>
    {film.titleEn && <div class="film-card__title-en" data-he={film.titleEn} data-en={film.titleHe || film.titleEn}>{film.titleEn}</div>}
    <div class="film-card__meta">
      {film.runtimeMin && <span>{film.runtimeMin}׳</span>}
      {cHe && <span data-he={cHe} data-en={cEn}>{cHe}</span>}
      {film.director && <span>· {film.director}</span>}
    </div>
    {next && (
      <div class="film-card__next" data-he={nextHe} data-en={nextEn}>{nextHe}</div>
    )}
  </div>
</a>
